{
  "title": "USB keyboard modification",
  "rules": [
    {
      "description": "Map Option+Space to Command+Space on USB Dongle device only",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": {
              "mandatory": [
                "option"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "spacebar",
              "modifiers": [
                "command"
              ]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 7847,
                  "product_id": 104,
                  "is_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
